{
  "manifest_version": 3,
  "name": "Azure DevOps Wiki Clone Page",
  "version": "1.0.0",
  "description": "Adds a clone option to the Azure DevOps wiki page context menu.",
  "homepage_url": "https://github.com/Br3zzly/azure-devops-clone-wiki-page",
  "content_scripts": [
    {
      "matches": ["https://dev.azure.com/*/_wiki/*"],
      "js": ["content.js"],
      "css": ["modal.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dialog.html"],
      "matches": ["https://dev.azure.com/*"]
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
